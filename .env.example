# Reco Trading Runtime Environment

# Exchange credentials (required)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Exchange mode guardrails
BINANCE_TESTNET=true
CONFIRM_MAINNET=false
ENVIRONMENT=testnet
RUNTIME_PROFILE=paper

# Database (required)
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/reco_trading_prod

# Core runtime defaults
BASE_SYMBOL=BTC/USDT
TIMEFRAME=5m
OPERATING_MODE=MINIMAL

# Remote API authentication
API_AUTH_KEY=replace_with_a_long_random_key

# Optional compatibility alias
BINANCE_SECRET=your_binance_api_secret
