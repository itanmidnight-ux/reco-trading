# ==============================
# RECO TRADING - ENVIRONMENT CONFIG
# ==============================

# Exchange credentials (required)
BINANCE_API_KEY=your_binance_api_key
BINANCE_API_SECRET=your_binance_api_secret

# Exchange mode guardrails
BINANCE_TESTNET=true
CONFIRM_MAINNET=false
ENVIRONMENT=testnet
RUNTIME_PROFILE=paper

# Multi-Symbol Trading (comma-separated list)
# Recommended: Major pairs + volatile altcoins for more opportunities
TRADING_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT,DOGE/USDT,XRP/USDT

# Database (required)
POSTGRES_DSN=postgresql+asyncpg://user:password@localhost:5432/reco_trading_prod

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Core runtime defaults
BASE_SYMBOL=BTC/USDT
TIMEFRAME=5m
CONFIRMATION_TIMEFRAME=15m
OPERATING_MODE=MINIMAL

# Loop timing (faster = more opportunities, but more API calls)
LOOP_SLEEP_SECONDS=6

# Position management
MAX_CONCURRENT_TRADES=2
MAX_TRADES_PER_DAY=15

# Risk management
RISK_PER_TRADE_FRACTION=0.015
MAX_TRADE_BALANCE_FRACTION=0.20

# Auto-Pause Control (safety features - set to false for manual control only)
# WARNING: Setting these to true will AUTO-PAUSE trading in certain conditions
DISABLE_AUTO_PAUSE=true
AUTO_PAUSE_ON_DRAWDOWN=false
AUTO_PAUSE_ON_CONSECUTIVE_LOSSES=false
AUTO_PAUSE_ON_EXCHANGE_FAILURE=false
AUTO_PAUSE_ON_SLIPPAGE=false
AUTO_PAUSE_ON_HIGH_SWING=false

# AI/ML Configuration (all enabled by default)
ENABLE_AUTO_IMPROVER=true
ENABLE_ML_ENGINE=true
ENABLE_CONTINUAL_LEARNING=true
ENABLE_META_LEARNING=true
ENABLE_TFT=true
ENABLE_NBEATS=true
ENABLE_ADVANCED_META_LEARNING=true
ENABLE_REINFORCEMENT_LEARNING=true
DRIFT_DETECTION=true
ONCHAIN_ANALYSIS=true

# LLM Mode (base = no external LLM, remove LLM dependency)
LLM_MODE=base
LLM_REMOTE_ENDPOINT=
LLM_REMOTE_MODEL=
LLM_REMOTE_API_KEY=

# Dashboard Security
DASHBOARD_AUTH_ENABLED=true
DASHBOARD_AUTH_MODE=token
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin
DASHBOARD_API_TOKEN=change_this_to_a_secure_token

# Feature Flags
FEATURE_MULTI_SYMBOL_ENABLED=true